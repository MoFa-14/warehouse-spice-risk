{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Pod BLE Monitor",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}\\pod_ble_monitor.py",
      "console": "integratedTerminal",
      "justMyCode": true,
      "args": ["--duration", "30"]
    },
    {
      "name": "Pod BLE Scan Only",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}\\pod_ble_monitor.py",
      "console": "integratedTerminal",
      "justMyCode": true,
      "args": ["--list-only", "--scan-timeout", "8"]
    },
    {
      "name": "Pod BLE Dump Services",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}\\pod_ble_monitor.py",
      "console": "integratedTerminal",
      "justMyCode": true,
      "args": ["--dump-services", "--scan-timeout", "8"]
    },
    {
      "name": "Pod Serial Monitor",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}\\pod_serial_monitor.py",
      "console": "integratedTerminal",
      "justMyCode": true,
      "args": ["--port", "COM6"]
    }
  ]
}
